<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Songmirun 팀별 통계 및 일괄 변경</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Supabase JS Library -->
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        @keyframes slideUp {
            from { transform: translateY(10px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
        .animate-slide-up {
            animation: slideUp 0.3s ease-out forwards;
        }
        ::-webkit-scrollbar {
            width: 4px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f1f1;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
    </style>
    <script type="module">
        const SUPABASE_URL = 'https://bwzvgqcfydznuwugyyio.supabase.co';
        const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJ3enZncWNmeWR6bnV3dWd5eWlvIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzMzNzU2MjcsImV4cCI6MjA4ODk1MTYyN30.SqQJ7w-SsPnm1wN03USOaR6_Fdn0JBzLn8tPhFYJWj8';
        
        let supabase;
        let members = [];

        async function init() {
            try {
                const { createClient } = window.supabase;
                supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
                await fetchData();
            } catch (error) {
                console.error("Init Error:", error);
                showError("시스템 초기화에 실패했습니다.");
            }
        }

        async function fetchData() {
            if (!supabase) return;
            const { data, error } = await supabase.from('songmirun_members').select('*');
            if (error) {
                showError(`데이터 로드 실패: ${error.message}`);
                return;
            }
            members = data || [];
            hideError();
            renderStats();
            updateTeamSelect();

            supabase.channel('public-members-changes')
                .on('postgres_changes', { event: '*', schema: 'public', table: 'songmirun_members' }, () => fetchData())
                .subscribe();
        }

        function renderStats() {
            const statsContainer = document.getElementById('stats-container');
            const totalCountEl = document.getElementById('total-count');
            const maleCountEl = document.getElementById('male-count');
            const femaleCountEl = document.getElementById('female-count');
            
            const teamStats = {};
            let globalMale = 0;
            let globalFemale = 0;

            members.forEach(m => {
                const teamName = m.team || "소속 없음";
                const gender = m.gender || "미지정";
                if (!teamStats[teamName]) teamStats[teamName] = { total: 0, male: 0, female: 0 };
                teamStats[teamName].total++;
                if (['남', '남성', 'M'].includes(gender)) { teamStats[teamName].male++; globalMale++; }
                else if (['여', '여성', 'F'].includes(gender)) { teamStats[teamName].female++; globalFemale++; }
            });

            totalCountEl.innerText = members.length;
            maleCountEl.innerText = globalMale;
            femaleCountEl.innerText = globalFemale;

            const sortedTeams = Object.entries(teamStats).sort((a, b) => b[1].total - a[1].total);
            
            if (sortedTeams.length === 0) {
                statsContainer.innerHTML = '<p class="text-gray-500 text-center py-10 font-medium">데이터가 없습니다.</p>';
                return;
            }

            statsContainer.innerHTML = sortedTeams.map(([team, stat]) => {
                const percentage = members.length > 0 ? ((stat.total / members.length) * 100).toFixed(1) : 0;
                return `
                    <div onclick="showTeamMembers('${team}')" class="bg-white p-3 rounded-xl shadow-sm border border-gray-100 mb-2 cursor-pointer transition-all hover:shadow-md hover:border-blue-200 active:scale-95 group">
                        <div class="flex justify-between items-center mb-1">
                            <span class="font-bold text-slate-700 group-hover:text-blue-600 transition-colors text-sm">${team}</span>
                            <span class="text-blue-600 font-bold bg-blue-50 px-1.5 py-0.5 rounded text-[11px]">${stat.total}명</span>
                        </div>
                        <div class="w-full bg-gray-100 rounded-full h-1 overflow-hidden flex">
                            <div class="bg-blue-500 h-1 transition-all duration-500" style="width: ${percentage}%"></div>
                        </div>
                    </div>
                `;
            }).join('');
        }

        async function showTeamMembers(teamName) {
            const modal = document.getElementById('member-modal');
            const title = document.getElementById('modal-title');
            const list = document.getElementById('modal-member-list');
            const summary = document.getElementById('modal-summary');
            
            title.innerText = teamName;
            summary.innerHTML = '';
            list.innerHTML = `
                <div class="flex flex-col items-center justify-center py-10">
                    <div class="animate-spin rounded-full h-6 w-6 border-b-2 border-blue-600 mb-2"></div>
                    <p class="text-gray-400 text-xs italic">로그 대조 중...</p>
                </div>`;
            
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';

            try {
                const { data: logs, error } = await supabase
                    .from('songmirun_logs')
                    .select('user_name')
                    .gte('run_date', '2026-03-01')
                    .lte('run_date', '2026-03-31');

                if (error) throw error;

                const activeUserNames = new Set((logs || []).map(log => log.user_name));
                const teamMembers = members
                    .filter(m => (m.team || "소속 없음") === teamName && activeUserNames.has(m.nickname))
                    .sort((a, b) => a.nickname.localeCompare(b.nickname, 'ko'));

                const mCount = teamMembers.filter(m => ['남', '남성', 'M'].includes(m.gender)).length;
                const fCount = teamMembers.filter(m => ['여', '여성', 'F'].includes(m.gender)).length;
                
                summary.innerHTML = `
                    <div class="flex justify-around items-center py-2 bg-slate-50 rounded-lg border border-slate-100">
                        <div class="text-center">
                            <div class="text-[9px] text-slate-400 font-bold uppercase tracking-tighter">Active</div>
                            <div class="text-sm font-black text-blue-600">${teamMembers.length}</div>
                        </div>
                        <div class="text-center">
                            <div class="text-[9px] text-slate-400 font-bold uppercase tracking-tighter">M</div>
                            <div class="text-sm font-black text-slate-600">${mCount}</div>
                        </div>
                        <div class="text-center">
                            <div class="text-[9px] text-slate-400 font-bold uppercase tracking-tighter">F</div>
                            <div class="text-sm font-black text-slate-600">${fCount}</div>
                        </div>
                    </div>
                `;

                if (teamMembers.length === 0) {
                    list.innerHTML = `
                        <div class="text-center py-10 px-6">
                            <p class="text-gray-400 text-xs font-medium">활동 내역 없음 (2026-03)</p>
                        </div>`;
                } else {
                    list.innerHTML = teamMembers.map((m, index) => `
                        <div class="flex justify-between items-center py-1.5 px-2 border-b border-slate-50 hover:bg-slate-50/50 transition-all animate-slide-up" style="animation-delay: ${index * 0.02}s">
                            <div class="flex items-center">
                                <span class="w-5 text-[10px] font-mono text-slate-300 mr-2">${index + 1}</span>
                                <span class="text-sm font-semibold text-slate-700">${m.nickname}</span>
                            </div>
                            <span class="text-[9px] font-bold px-1.5 py-0.5 rounded ${['남', '남성', 'M'].includes(m.gender) ? 'text-blue-500 bg-blue-50' : 'text-pink-500 bg-pink-50'}">
                                ${m.gender || '-'}
                            </span>
                        </div>
                    `).join('');
                }
            } catch (err) {
                list.innerHTML = `<div class="p-3 text-red-500 text-[10px] text-center">오류: ${err.message}</div>`;
            }
        }

        function closeModal() {
            document.getElementById('member-modal').classList.add('hidden');
            document.body.style.overflow = 'auto';
        }

        function updateTeamSelect() {
            const select = document.getElementById('target-team');
            const teams = [...new Set(members.map(m => m.team).filter(t => t))].sort();
            const currentValue = select.value;
            select.innerHTML = '<option value="">변경할 팀 선택</option>' + 
                teams.map(t => `<option value="${t}">${t}</option>`).join('');
            if (teams.includes(currentValue)) select.value = currentValue;
        }

        async function bulkUpdateTeam() {
            const targetTeam = document.getElementById('target-team').value;
            const nicknamesInput = document.getElementById('nickname-list').value;
            if (!targetTeam) { alert("변경할 팀을 선택해주세요."); return; }
            const nicknames = nicknamesInput.split('\n').map(n => n.trim()).filter(n => n.length > 0);
            if (nicknames.length === 0) { alert("변경할 닉네임을 입력해주세요."); return; }

            try {
                const { error } = await supabase
                    .from('songmirun_members')
                    .update({ team: targetTeam })
                    .in('nickname', nicknames);
                if (error) throw error;
                alert(`성공적으로 변경되었습니다.`);
                document.getElementById('nickname-list').value = "";
            } catch (error) {
                alert("업데이트 실패: " + error.message);
            }
        }

        function showError(msg) {
            const errorEl = document.getElementById('error-msg');
            errorEl.innerText = msg;
            errorEl.classList.remove('hidden');
        }
        
        function hideError() {
            document.getElementById('error-msg').classList.add('hidden');
        }

        window.showTeamMembers = showTeamMembers;
        window.closeModal = closeModal;
        window.bulkUpdateTeam = bulkUpdateTeam;
        window.onload = init;
    </script>
</head>
<body class="bg-slate-50 min-h-screen p-4 md:p-6 font-sans text-slate-900">
    <div class="max-w-md mx-auto">
        <header class="mb-6 text-center">
            <h1 class="text-2xl font-black text-slate-900 tracking-tight">Songmirun <span class="text-blue-600">Admin</span></h1>
            <p class="text-slate-400 text-[10px] font-bold mt-1 uppercase tracking-widest italic">3월 활동자 대조 시스템</p>
        </header>

        <div id="error-msg" class="hidden bg-red-50 text-red-600 px-4 py-2 rounded-xl mb-4 text-[11px] font-bold"></div>

        <!-- 전체 통계 요약 (콤팩트) -->
        <div class="bg-slate-900 rounded-3xl p-6 mb-6 text-white shadow-xl relative overflow-hidden">
            <div class="relative z-10 flex justify-between items-center">
                <div>
                    <div class="text-[9px] opacity-40 font-black uppercase tracking-widest mb-1">Total Members</div>
                    <div class="text-4xl font-black tracking-tighter" id="total-count">0</div>
                </div>
                <div class="flex gap-4 text-right">
                    <div>
                        <div class="text-[9px] opacity-40 font-black mb-1">Male</div>
                        <div class="text-lg font-black text-blue-400" id="male-count">0</div>
                    </div>
                    <div>
                        <div class="text-[9px] opacity-40 font-black mb-1">Female</div>
                        <div class="text-lg font-black text-pink-400" id="female-count">0</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 팀 리스트 -->
        <div class="flex items-center gap-2 mb-3 px-1">
            <h2 class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Team Stats</h2>
            <div class="flex-1 h-[1px] bg-slate-200"></div>
        </div>
        <div id="stats-container" class="mb-8">
            <div class="flex justify-center py-6"><div class="animate-spin rounded-full h-5 w-5 border-b-2 border-blue-600"></div></div>
        </div>

        <!-- 일괄 변경 -->
        <div class="bg-white rounded-3xl p-6 shadow-sm border border-slate-100">
            <h2 class="text-sm font-black text-slate-800 mb-4 flex items-center gap-2">
                <span class="w-1.5 h-4 bg-blue-600 rounded-full"></span>
                일괄 팀 변경
            </h2>
            <div class="space-y-3">
                <select id="target-team" class="w-full bg-slate-50 border-slate-100 rounded-xl p-3 border outline-none text-xs font-bold text-slate-600 appearance-none focus:border-blue-500 transition-colors">
                    <option value="">대상 팀 선택</option>
                </select>
                <textarea id="nickname-list" rows="4" class="w-full bg-slate-50 border-slate-100 rounded-xl p-3 border text-xs font-medium outline-none focus:border-blue-500 transition-colors placeholder:text-slate-300" placeholder="닉네임 목록 (줄바꿈 구분)"></textarea>
                <button onclick="bulkUpdateTeam()" class="w-full bg-slate-900 hover:bg-blue-600 text-white font-black py-3 rounded-xl text-xs transition-all active:scale-[0.98]">업데이트 적용</button>
            </div>
        </div>
    </div>

    <!-- 멤버 명단 모달 (초슬림 버전) -->
    <div id="member-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4">
        <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-sm" onclick="closeModal()"></div>
        <div class="relative bg-white w-full max-w-[320px] rounded-2xl shadow-2xl overflow-hidden flex flex-col max-h-[70vh]">
            <div class="px-4 py-3 border-b border-slate-50 flex justify-between items-center bg-white">
                <div>
                    <h3 id="modal-title" class="text-sm font-black text-slate-800">팀 명단</h3>
                </div>
                <button onclick="closeModal()" class="p-1 text-slate-300 hover:text-slate-600 transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            
            <div class="px-4 py-2">
                <div id="modal-summary"></div>
            </div>
            
            <div id="modal-member-list" class="px-2 py-1 overflow-y-auto flex-1 min-h-[100px]">
                <!-- 멤버 리스트 -->
            </div>
            
            <div class="p-3 bg-slate-50 border-t border-slate-100">
                <button onclick="closeModal()" class="w-full bg-white border border-slate-200 text-slate-500 font-bold py-2 rounded-lg text-[11px] transition-all active:scale-95">닫기</button>
            </div>
        </div>
    </div>
</body>
</html>
